{
  "info": {
    "_postman_id": "7252d2fe-5718-4e4f-bf27-8b3a4e7ad436",
    "name": "MUI Public",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "1216570"
  },
  "item": [
    {
      "name": "mui.com/about",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Visualization Script",
              "// Visualization Script",
              "const template = `",
              "  <style>",
              "    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1f2937; margin: 16px; }",
              "    .header { margin-bottom: 16px; }",
              "    .title { font-size: 20px; font-weight: 600; margin: 0 0 4px; }",
              "    .count { color: #6b7280; font-size: 13px; margin: 0; }",
              "    table { border-collapse: collapse; width: 100%; font-size: 14px; }",
              "    th, td { border: 1px solid #e5e7eb; padding: 10px 12px; text-align: left; vertical-align: top; }",
              "    th { background: #f9fafb; font-weight: 600; }",
              "    tbody tr:nth-child(even) { background: #fcfcfd; }",
              "    .muted { color: #9ca3af; }",
              "    a { color: #2563eb; text-decoration: none; }",
              "    a:hover { text-decoration: underline; }",
              "  </style>",
              "",
              "  <div class=\"header\">",
              "    <h1 class=\"title\">People</h1>",
              "    <p class=\"count\">Total: {{total}}</p>",
              "  </div>",
              "",
              "  <table>",
              "    <thead>",
              "      <tr>",
              "        <th>Name</th>",
              "        <th>Title</th>",
              "        <th>About</th>",
              "        <th>Location</th>",
              "        <th>GitHub</th>",
              "        <th>Twitter</th>",
              "      </tr>",
              "    </thead>",
              "    <tbody>",
              "      {{#each people}}",
              "      <tr>",
              "        <td>{{name}}</td>",
              "        <td>{{title}}</td>",
              "        <td>{{about}}</td>",
              "        <td>{{location}}</td>",
              "        <td>",
              "          {{#if githubUrl}}",
              "            <a href=\"{{githubUrl}}\" target=\"_blank\">{{github}}</a>",
              "          {{else}}",
              "            <span class=\"muted\">—</span>",
              "          {{/if}}",
              "        </td>",
              "        <td>",
              "          {{#if twitterUrl}}",
              "            <a href=\"{{twitterUrl}}\" target=\"_blank\">{{twitter}}</a>",
              "          {{else}}",
              "            <span class=\"muted\">—</span>",
              "          {{/if}}",
              "        </td>",
              "      </tr>",
              "      {{/each}}",
              "    </tbody>",
              "  </table>",
              "`;",
              "",
              "function createPayload() {",
              "  const response = pm.response.json();",
              "  const people = Array.isArray(response?.people) ? response.people : [];",
              "",
              "  return {",
              "    total: people.length,",
              "    people: people.map((person) => {",
              "      const github = person?.github ? String(person.github) : '';",
              "      const twitter = person?.twitter ? String(person.twitter) : '';",
              "",
              "      return {",
              "        name: person?.name || '—',",
              "        title: person?.title || '—',",
              "        about: person?.about || '—',",
              "        location: person?.location || '—',",
              "        github: github || '—',",
              "        twitter: twitter || '—',",
              "        githubUrl: github ? `https://github.com/${github}` : '',",
              "        twitterUrl: twitter ? `https://twitter.com/${twitter}` : ''",
              "      };",
              "    })",
              "  };",
              "}",
              "",
              "pm.visualizer.set(template, createPayload());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://frontend-public.mui.com/api/mui-about",
          "protocol": "https",
          "host": ["frontend-public", "mui", "com"],
          "path": ["api", "mui-about"]
        }
      },
      "response": []
    }
  ]
}
