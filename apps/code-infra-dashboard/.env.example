# A personal API token for CircleCI
# Can be created via https://app.circleci.com/settings/user/tokens
export CIRCLECI_TOKEN=token;

# MUI X Pro/Premium license key
# Required for MUI X Pro components (charts-pro, date-pickers-pro, etc.)
NEXT_PUBLIC_MUI_LICENSE=your-license-key-here

AWS_ACCESS_KEY_ID=key-id
AWS_SECRET_ACCESS_KEY=secret

# GitHub authentication (one of the following):
# Option 1: GitHub App (preferred)
GITHUB_APP_ID=app-id
GITHUB_APP_PRIVATE_KEY=private-key
GITHUB_APP_INSTALLATION_ID=installation-id
# Option 2: Personal access token
GITHUB_TOKEN=token
BASTION_HOST=host
BASTION_USERNAME=username
BASTION_SSH_KEY=key
STORE_PRODUCTION_READ_HOST=host
STORE_PRODUCTION_READ_USERNAME=username
STORE_PRODUCTION_READ_PASSWORD=password
STORE_PRODUCTION_READ_DATABASE=database
HIBOB_TOKEN_READ_STANDARD=token
ZENDESK=token
