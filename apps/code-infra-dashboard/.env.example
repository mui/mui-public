# A personal API token for CircleCI
# Can be created via https://app.circleci.com/settings/user/tokens
export CIRCLECI_TOKEN=token;

# MUI X Pro/Premium license key
# Required for MUI X Pro components (charts-pro, date-pickers-pro, etc.)
NEXT_PUBLIC_MUI_LICENSE=your-license-key-here

AWS_ACCESS_KEY_ID=key-id
AWS_SECRET_ACCESS_KEY=secret
AWS_REGION=us-east-1