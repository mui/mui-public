{
  "name": "docs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "pnpm build && pnpm link-check",
    "link-check": "tsx ./scripts/reportBrokenLinks.mts",
    "start": "serve ./export",
    "docs-infra": "docs-infra",
    "validate": "docs-infra validate --command 'pnpm validate'",
    "screenshot": "docs-infra browser --script screenshot:unconfined --playwright-version 1.59.1 --",
    "screenshot:unconfined": "playwright test",
    "screenshot:codegen": "playwright codegen"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mui/internal-docs-infra": "workspace:^",
    "@next/mdx": "^16.2.1",
    "@types/mdx": "^2.0.13",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-runner": "^1.0.5",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "use-editable": "^2.3.3",
    "vscode-oniguruma": "^2.0.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.1",
    "@playwright/test": "1.59.1",
    "@types/node": "22.19.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@wooorm/starry-night": "3.9.0",
    "serve": "14.2.6",
    "typescript": "6.0.2"
  }
}
