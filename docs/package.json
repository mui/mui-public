{
  "name": "docs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "pnpm build && pnpm link-check",
    "link-check": "tsx ./scripts/reportBrokenLinks.mts",
    "start": "serve ./export",
    "docs-infra": "node ./scripts/runDocsInfra.mjs",
    "validate": "pnpm docs-infra validate --command 'pnpm validate'",
    "test:e2e": "pnpm docs-infra browser --script test:e2e:unconfined --playwright-version 1.59.1 --",
    "test:e2e:unconfined": "playwright test",
    "test:e2e:codegen": "playwright codegen"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mui/internal-docs-infra": "workspace:^",
    "@next/mdx": "^16.2.6",
    "@types/mdx": "^2.0.14",
    "lucide-react": "^0.577.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "vscode-oniguruma": "^2.0.1",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.6",
    "@playwright/test": "1.61.1",
    "@types/node": "22.19.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@wooorm/starry-night": "3.10.0",
    "serve": "14.2.6",
    "typescript": "6.0.3"
  }
}
